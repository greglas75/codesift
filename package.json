{
  "name": "codesift-mcp",
  "version": "0.5.10",
  "description": "MCP server for code intelligence — 146 tools for symbol search, call graph, semantic search, route tracing, community detection, LSP bridge, secret detection, conversation search, and Hono framework intelligence",
  "license": "BSL-1.1",
  "author": "Greg Laskowski",
  "type": "module",
  "bin": {
    "codesift-mcp": "./dist/server.js",
    "codesift": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist",
    "rules",
    "src/parser/languages",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/parser/languages dist/parser/",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "download-wasm": "tsx scripts/download-wasm.ts",
    "prepublishOnly": "npm run build && npm test",
    "postinstall": "echo '\n  ✨ CodeSift MCP installed. Run setup for your platform:\n\n     codesift setup claude       # Claude Code\n     codesift setup cursor       # Cursor\n     codesift setup codex        # Codex CLI\n     codesift setup gemini       # Gemini CLI\n     codesift setup antigravity  # Google Antigravity\n     codesift setup all          # All platforms\n'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mrleebo/prisma-ast": "^0.15.0",
    "@sanity-labs/secret-scan": "^1.1.0",
    "chokidar": "^4.0.0",
    "ignore": "^6.0.0",
    "picomatch": "^4.0.4",
    "web-tree-sitter": "^0.24.0",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "openai": "^6.0.0",
    "voyageai": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.2",
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "code-search",
    "tree-sitter",
    "semantic-search",
    "claude",
    "anthropic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/greglas/codesift-mcp"
  }
}
